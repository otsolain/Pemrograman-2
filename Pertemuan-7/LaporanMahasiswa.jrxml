<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="laporanMahasiswa"
              pageWidth="842" pageHeight="595"
              orientation="Landscape"
              columnWidth="782" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20">

    <!-- Query SQL untuk mengambil data -->
    <queryString>
        <![CDATA[SELECT nim, nama, semester, kelas FROM datamhs ORDER BY nama ASC]]>
    </queryString>

    <!-- Definisi field dari hasil query -->
    <field name="nim"      class="java.lang.String"/>
    <field name="nama"     class="java.lang.String"/>
    <field name="semester" class="java.lang.Integer"/>
    <field name="kelas"    class="java.lang.String"/>

    <!-- Parameter opsional -->
    <parameter name="judul" class="java.lang.String"/>

    <!-- Header laporan (judul) -->
    <title>
        <band height="50">
            <textField>
                <reportElement x="0" y="10" width="782" height="30"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{judul}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- Header kolom tabel -->
    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement x="0"   y="0" width="120" height="20"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[NIM]]></text>
            </staticText>
            <staticText>
                <reportElement x="120" y="0" width="250" height="20"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Nama]]></text>
            </staticText>
            <staticText>
                <reportElement x="370" y="0" width="100" height="20"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Semester]]></text>
            </staticText>
            <staticText>
                <reportElement x="470" y="0" width="80" height="20"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Kelas]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- Isi data (detail) -->
    <detail>
        <band height="20">
            <textField>
                <reportElement x="0"   y="0" width="120" height="20"/>
                <textFieldExpression><![CDATA[$F{nim}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="0" width="250" height="20"/>
                <textFieldExpression><![CDATA[$F{nama}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="370" y="0" width="100" height="20"/>
                <textFieldExpression><![CDATA[$F{semester}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="470" y="0" width="80" height="20"/>
                <textFieldExpression><![CDATA[$F{kelas}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

</jasperReport>
